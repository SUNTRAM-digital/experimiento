.env
.env.local
.env.production
.env.staging
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
secrets/
credentials/

# ══════════════════════════════════════════════════════════════════════════════
# DATOS EN TIEMPO REAL — estado del bot, posiciones, historial
