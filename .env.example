# ============================================================
# POLYMARKET CREDENTIALS  (obligatorio para operar)
# ============================================================

# Private key de tu wallet (MetaMask > ... > Account Details > Export Private Key)
# NUNCA compartas esta key — quien la tenga controla tus fondos
POLY_PRIVATE_KEY=0x_TU_PRIVATE_KEY_AQUI

# Tipo de firma:
#   0 = EOA (MetaMask, hardware wallet)
#   1 = Magic/Email (cuenta creada con email en Polymarket)
#   2 = Gnosis Safe
POLY_SIGNATURE_TYPE=0

# Dirección pública de tu wallet
POLY_WALLET_ADDRESS=0x_TU_WALLET_ADDRESS_AQUI

# ============================================================
# ANTHROPIC / CLAUDE  (obligatorio para análisis automático)
# ============================================================

# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# Modelo a usar:
#   claude-haiku-4-5   → rápido y barato (~$0.001 por análisis)  ← RECOMENDADO
#   claude-sonnet-4-6  → más profundo (~$0.005 por análisis)
#   claude-opus-4-6    → máxima calidad (~$0.015 por análisis)
CLAUDE_MODEL=claude-haiku-4-5

# ============================================================
# APIS OPCIONALES
# ============================================================

# CoinMarketCap — datos macro BTC (señal de tendencia 1h)
# Free tier funciona. Obtener en: https://pro.coinmarketcap.com/account
CMC_API_KEY=tu_cmc_api_key_aqui

# Telonex — OFI real on-chain + smart wallet tracking para UpDown
# Sin key el bot funciona con señales proxy (menos precisas)
# Registro gratuito en: https://telonex.io
TELONEX_API_KEY=tu_telonex_api_key_aqui

# ============================================================
# PARÁMETROS DEL BOT  (todos ajustables también desde la UI)
# ============================================================

# --- Posición ---
MAX_POSITION_USDC=5.0
MIN_POSITION_USDC=1.0
KELLY_FRACTION=0.25

# --- Edge mínimo ---
# 7% = umbral óptimo según análisis de 400M trades (74% hit rate)
MIN_EV_THRESHOLD=0.07

# --- Riesgo ---
MAX_DAILY_LOSS_PCT=0.20

# --- Calidad de mercado ---
MIN_LIQUIDITY_USDC=50.0
MAX_SPREAD_PCT=0.60
MIN_VOLUME_24H_USDC=5.0
MIN_BOOK_DEPTH_USDC=200.0

# --- Operación ---
SCAN_INTERVAL_MINUTES=30
MAX_HOURS_TO_RESOLUTION=72

# --- Weather ---
WEATHER_ENABLED=true

# --- BTC directional ---
BTC_ENABLED=true
BTC_MAX_POSITION_USDC=3.0
BTC_MAX_HOURS_TO_RESOLUTION=96

# --- UpDown (5m/15m) ---
UPDOWN_5M_ENABLED=true
UPDOWN_15M_ENABLED=true
UPDOWN_MAX_USDC=1.0
UPDOWN_MAX_CONSECUTIVE_LOSSES=5

# --- Telonex weights (no tocar si no sabes lo que hacen) ---
TELONEX_ENABLED=true
TELONEX_SMART_WALLET_WEIGHT=0.10
TELONEX_REAL_OFI_WEIGHT=0.12
