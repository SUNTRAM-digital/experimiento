# ============================================================
# POLYMARKET CREDENTIALS
# ============================================================

# Tu private key de wallet (MetaMask u otro EOA)
# Para obtenerla: MetaMask > ... > Account Details > Export Private Key
POLY_PRIVATE_KEY=0x_TU_PRIVATE_KEY_AQUI

# Tipo de wallet:
#   0 = EOA (MetaMask, hardware wallet) <-- usa este si conectaste MetaMask
#   1 = Magic/Email (cuenta creada con email en Polymarket)
#   2 = Gnosis Safe
POLY_SIGNATURE_TYPE=1

# Dirección de tu wallet (la que aparece en MetaMask o en Polymarket)
POLY_WALLET_ADDRESS=0x_TU_WALLET_ADDRESS_AQUI

# ============================================================
# PARAMETROS DEL BOT (todos ajustables desde la interfaz)
# ============================================================

# USDC maximo por trade ($)
MAX_POSITION_USDC=5.0

# USDC minimo por trade ($)
MIN_POSITION_USDC=1.0

# Fraccion de Kelly a usar (0.25 = 25% Kelly, mas conservador)
KELLY_FRACTION=0.25

# EV minimo para abrir posicion (0.10 = 10% de edge)
MIN_EV_THRESHOLD=0.10

# Perdida maxima diaria (porcentaje del balance inicial del dia)
MAX_DAILY_LOSS_PCT=0.20

# Solo entrar en mercados que cierran en menos de X horas
MAX_HOURS_TO_RESOLUTION=24

# Liquidez minima del mercado en USDC
MIN_LIQUIDITY_USDC=50.0

# Cada cuantos minutos escanear mercados
SCAN_INTERVAL_MINUTES=30
