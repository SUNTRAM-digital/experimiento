# ============================================================
# POLYMARKET CREDENTIALS
# ============================================================

# Tu private key de wallet (MetaMask u otro EOA)
# Para obtenerla: MetaMask > ... > Account Details > Export Private Key
# NUNCA compartas esta key — quien la tenga controla tus fondos
POLY_PRIVATE_KEY=0x_TU_PRIVATE_KEY_AQUI

# Tipo de wallet:
#   0 = EOA (MetaMask, hardware wallet) <-- usa este si conectaste MetaMask
#   1 = Magic/Email (cuenta creada con email en Polymarket)
#   2 = Gnosis Safe
POLY_SIGNATURE_TYPE=0

# Dirección publica de tu wallet (la que aparece en MetaMask o en Polymarket)
POLY_WALLET_ADDRESS=0x_TU_WALLET_ADDRESS_AQUI

# ============================================================
# APIs OPCIONALES
# ============================================================

# CoinMarketCap API Key (para datos BTC — free tier funciona)
# Obtener en: https://pro.coinmarketcap.com/account
CMC_API_KEY=tu_cmc_api_key_aqui

# Anthropic API Key (para Claude Analyst — OBLIGATORIO para que el bot opere)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# Modelo Claude a usar (default: claude-haiku-4-5 — rapido y economico)
# Opciones: claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5

# ============================================================
# PARAMETROS DEL BOT (todos ajustables tambien desde la UI)
# ============================================================

MAX_POSITION_USDC=5.0
MIN_POSITION_USDC=1.0
KELLY_FRACTION=0.25
MIN_EV_THRESHOLD=0.10
MAX_DAILY_LOSS_PCT=0.20
MAX_HOURS_TO_RESOLUTION=24
MIN_LIQUIDITY_USDC=50.0
SCAN_INTERVAL_MINUTES=30
MAX_SPREAD_PCT=0.60
MIN_VOLUME_24H_USDC=5.0

# ============================================================
# TELEGRAM (para notificaciones y control del bot)
# ============================================================

TELEGRAM_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
